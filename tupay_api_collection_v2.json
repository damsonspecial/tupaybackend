						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"amount\": 100000,\n    \"from_currency\": \"NGN\",\n    \"to_currency\": \"CNY\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/swap",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"swap"
							]
						}
					}
				},
