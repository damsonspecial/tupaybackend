					"name": "Get Ledger History",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/ledger/1",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"ledger",
								"1"
							]
						}
					}
				}
			]
		},
		{
			"name": "Webhooks",
			"item": [
				{
					"name": "Settlement Webhook",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "X-Tupay-Signature",
								"value": "YOUR_HMAC_SIGNATURE",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"user_id\": 1,\n    \"wallet_id\": 1,\n    \"amount\": 500000,\n    \"currency\": \"NGN\",\n    \"reference\": \"SETTLE_99999\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/webhooks/settlement",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"webhooks",
								"settlement"
							]
						}
					}
				}
			]
		}
